# ============================================================
# TUYUL TRADING SWARM — Environment Variables
# Copy ke .env dan isi nilai yang sesuai.
# JANGAN commit .env ke git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="tuyul-trading-swarm"
APP_ENV="dev"                    # dev | staging | prod
DEBUG="true"
ENABLE_DEV_ROUTES="true"         # true = skip auth di dev
LOG_LEVEL="INFO"

# ── Server ────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT="8000"
RUN_MODE="all"                   # all | api-only

# ── Redis (Memory Fabric & Event Bus) ─────────────────────────
REDIS_URL="redis://localhost:6379/0"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"
REDIS_PREFIX="tuyul"
REDIS_SOCKET_TIMEOUT_SEC="5"

# ── Auth / Dashboard ──────────────────────────────────────────
DASHBOARD_JWT_SECRET="change-me-to-at-least-32-random-chars!!"
DASHBOARD_JWT_ALGO="HS256"
DASHBOARD_TOKEN_EXPIRE_MIN="60"
DASHBOARD_API_KEY=""

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:8000,http://127.0.0.1:8000"

# ── Trading Rules ─────────────────────────────────────────────
MIN_RR_RATIO="2.0"               # Minimum Risk:Reward ratio
MAX_PIP_RISK="50.0"              # Maximum pip risk per trade
MAX_ACCOUNT_RISK_PCT="1.0"       # Maximum % account per trade
DEFAULT_ACCOUNT_BALANCE="100000" # Default balance untuk sizing
PIP_VALUE_PER_LOT="10.0"         # USD per pip per lot (standard)

# ── Psychology Rules ──────────────────────────────────────────
MAX_DAILY_TRADES="3"             # Maximum trade per hari
MAX_CONSECUTIVE_LOSSES="2"       # Maksimal loss berturut-turut sebelum review
MAX_DAILY_LOSS_PCT="2.0"         # Maximum daily loss % sebelum HALT

# ── Memory TTL ────────────────────────────────────────────────
MEMORY_DECISION_TTL_SEC="172800" # 48 jam
MEMORY_WATCHLIST_TTL_SEC="43200" # 12 jam
MEMORY_HANDOFF_TTL_SEC="604800"  # 7 hari

# ── Journal ────────────────────────────────────────────────────
JOURNAL_DIR="./storage/journal"

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ENABLED="false"

# ── Observability ─────────────────────────────────────────────
OTEL_ENABLED="false"
OTEL_EXPORTER_OTLP_ENDPOINT=""
