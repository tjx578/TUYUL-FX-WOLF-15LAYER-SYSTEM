{
  "typeCheckingMode": "standard",
  "pythonVersion": "3.11",
  "reportMissingTypeStubs": false,
  "reportUnnecessaryTypeIgnoreComment": true,
  "include": ["."],
  "exclude": [
    "node_modules",
    ".venv",
    "__pycache__",
    "dashboard/nextjs",
    "migrations",
    "**/.*",
    "scripts",
    "deploy",
    "docs",
    "ops",
    "load",
    "e2e"
  ],
  "extraPaths": [
    ".",
    "./services/api",
    "./infrastructure"
  ],
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        ".",
        "./services/api",
        "./infrastructure"
      ]
    },
    {
      "root": "api",
      "extraPaths": [
        ".",
        "../",
        "./",
        "../infrastructure"
      ]
    },
    {
      "root": "tests",
      "extraPaths": [
        ".",
        "../",
        "../services/api",
        "../infrastructure"
      ]
    }
  ],
  "venvPath": ".",
  "venv": ".venv"
}
