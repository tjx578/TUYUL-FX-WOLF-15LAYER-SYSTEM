{
  "typeCheckingMode": "standard",
  "pythonVersion": "3.11",
  "reportMissingTypeStubs": false,
  "reportUnnecessaryTypeIgnoreComment": true,
  "include": ["."],
  "exclude": [
    "node_modules",
    ".venv",
    "__pycache__",
    "dashboard/nextjs",
    "migrations",
    "**/.*",
    "scripts",
    "deploy",
    "docs",
    "ops",
    "load",
    "e2e"
  ],
  "extraPaths": [
    "${workspaceFolder}"
  ],
  "venvPath": ".",
  "venv": ".venv"
}
