# ==========================================================
# TUYUL FX — WOLF 15-LAYER SYSTEM (.env)
# Copy this file to ".env" and fill in the values.
# NEVER commit real secrets to git.
# ==========================================================

# -----------------------
# APP MODE
# -----------------------
APP_NAME="tuyul-fx-wolf-15layer-system"
APP_ENV="dev"                 # dev | staging | prod
ENV="development"             # development | production (api_server.py)
DEBUG="true"
ENABLE_DEV_ROUTES="true"
TRADING_MODE="paper"          # paper | live
LOG_LEVEL="INFO"              # DEBUG | INFO | WARNING | ERROR
TIMEZONE="Asia/Singapore"     # GMT+8 timezone for local display and session detection

# -----------------------
# FINNHUB (Market Feed)
# -----------------------
FINNHUB_API_KEY="YOUR_FINNHUB_API_KEY"
# WebSocket URL (override if using premium endpoint)
# FINNHUB_WS_URL="wss://ws.finnhub.io"
# REST API base URL
# FINNHUB_REST_URL="https://finnhub.io/api/v1"

# -----------------------
# NEWS / CALENDAR
# -----------------------
NEWS_PROVIDER="finnhub"       # finnhub | off
NEWS_LOCK_ENABLED="true"      # true | false

# -----------------------
# REDIS (Storage / Snapshots / Context)
# -----------------------
REDIS_URL="redis://localhost:6379/0"
REDIS_PREFIX="wolf15"
REDIS_SOCKET_TIMEOUT_SEC="5"

# Candle history key prefixes — reader/consumer side (comma-separated, first-wins).
# Must match the prefix used by your ingest writer.
# Default (no override needed for standard deploys):
#   wolf15:candle_history,candle_history
# If writer uses a different namespace (e.g. deployed on a separate Redis DB),
# set this to the writer's prefix to fix bars=0 without any code changes.
CANDLE_HISTORY_KEY_PREFIXES="wolf15:candle_history,candle_history"

# PostgreSQL durable backup (optional write-behind persistence)
DATABASE_URL="postgresql://wolf_user:secure_password@localhost:5432/wolf_trading"

# Context mode: local (in-memory) or redis (cross-container via Redis)
# - local: For single-process / local dev (default)
# - redis: For multi-container deployments (ingest + engine separation)
CONTEXT_MODE="local"

# -----------------------
# TELEGRAM ALERTS
# -----------------------
TELEGRAM_ENABLED="false"      # true | false
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"

# -----------------------
# DASHBOARD (Read-Only)
# -----------------------
DASHBOARD_ENABLED="true"      # true | false
DASHBOARD_HOST="0.0.0.0"
DASHBOARD_PORT="8000"

# CORS origins (comma-separated)
# Dev: http://localhost:3000
# Vercel prod: https://yourdomain.com
# Vercel preview: https://*.vercel.app (add specific preview URLs as needed)
CORS_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Dashboard auth secrets (required in all envs; use >=32 random chars)
DASHBOARD_JWT_SECRET=""
DASHBOARD_JWT_ALGO="HS256"
DASHBOARD_TOKEN_EXPIRE_MIN="60"
# Optional static API key for service-to-service calls (EA, scripts)
DASHBOARD_API_KEY=""

# Production aliases (legacy-compatible in code)
JWT_SECRET="replace-with-strong-random-secret"
JWT_ALGORITHM="HS256"
JWT_TTL_MINUTES="30"

# -----------------------
# RATE LIMITING
# -----------------------
RATE_LIMIT_ENABLED="true"              # true | false
RATE_LIMIT_REQUESTS_PER_MIN="120"      # Max HTTP requests per IP per minute
RATE_LIMIT_BURST="20"                  # Extra burst tolerance above base rate
RATE_LIMIT_WS_PER_MIN="10"            # Max WebSocket upgrades per IP per minute
RATE_LIMIT_REDIS_PREFIX="ratelimit:"   # Redis key prefix for distributed limiter

# WebSocket hardening
WS_REQUIRE_AUTH="true"
WS_PING_INTERVAL="15"
WS_HEARTBEAT_TIMEOUT="30"
WS_MAX_CONNECTIONS="50"
WS_MAX_CONNECTIONS_PER_MIN="10"

# Governance hardening
COMPLIANCE_MODE_DEFAULT="true"
CONFIG_LOCK_PROTECTED_FIELDS="true"
REQUIRE_ADMIN_PIN_FOR_HIGH_RISK="true"
ADMIN_PIN_HASH=""

# Proxy / transport hardening
TRUSTED_PROXY_ENABLED="false"
FORCE_HTTPS="false"

# Audit controls
AUDIT_LOG_ENABLED="true"

# Price Feed & Monitoring
PRICE_FEED_INTERVAL_SEC="2"       # Interval for updating price cache from LiveContextBus
PRICE_WATCHER_INTERVAL_SEC="2"    # Interval for monitoring trade state transitions

# Default Account Settings
DEFAULT_ACCOUNT_BALANCE="100000"
DEFAULT_MAX_DAILY_DD_PERCENT="4.0"
DEFAULT_MAX_TOTAL_DD_PERCENT="8.0"

# -----------------------
# EXECUTION / EA INTERFACE
# (EA will read command outputs, not generate signals.)
# -----------------------
EA_BRIDGE_ENABLED="true"      # true | false
EA_COMMAND_OUT_DIR="./storage/ea_commands"
EA_STATE_IN_DIR="./storage/ea_state"

# -----------------------
# PROP FIRM / RISK SETTINGS (Runtime toggles)
# Hard thresholds remain inside config/constitution.yaml (locked).
# -----------------------
PROP_FIRM_MODE="true"         # true | false
MAX_CONCURRENT_TRADES="1"

# -----------------------
# OPTIONAL: BROKER / MT5 bridge placeholders
# (If you run separate executor service)
# -----------------------
BROKER_EXECUTOR="off"         # off | mt5_bridge | custom
BROKER_ACCOUNT_ID=""
BROKER_SERVER=""
BROKER_PASSWORD=""

# -----------------------
# SECURITY / MISC
# -----------------------
ALLOW_MARKET_EXECUTION="false"  # MUST stay false (constitutional)
ALLOW_DASHBOARD_WRITE="false"    # MUST stay false (constitutional)

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me_to_a_strong_random_password

# Railway Redis addon auto-injects these (no underscores).
# You do NOT need to set them manually — they are read as fallbacks
# when REDIS_URL and REDIS_HOST/PORT/PASSWORD are absent.
# REDISHOST=
# REDISPORT=
# REDISUSER=
# REDISPASSWORD=

# --- App Scaling ---
WEB_CONCURRENCY=1                    # Keep at 1 for WebSocket state consistency
APP_PORT=8000

# --- Single-Container Ingest ---
# Set to true when running API + ingest in the same container (Railway/Render)
# Set to false when ingest_service runs as a separate container
EMBED_INGEST="false"

# -----------------------
# DISTRIBUTED SERVICES (Railway)
# -----------------------
# API service
ENGINE_MODE="paper"

# Engine service
ORCHESTRATOR_CHANNEL="wolf15:orchestrator:commands"

# Vercel dashboard
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"
NEXT_PUBLIC_WS_URL="ws://localhost:8000"
