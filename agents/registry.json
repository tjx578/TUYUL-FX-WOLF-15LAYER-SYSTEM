      ],
      "handoff_to": [
        "architecture",
        "implementation",
        "verification"
      ],
      "topology_support": [
        "single",
        "pipeline"
      ],
      "risk_profile": "medium",
      "execution_cost": "medium",
      "memory_policy": "write",
      "completion_criteria": [
        "scope explicit",
        "acceptance criteria testable"
