{
  "meta": {
    "name": "Ultimate Agent Registry",
    "version": "2.0.0",
    "status": "draft-executable-spec",
    "entrypoint": "ultimate_agent_router",
    "default_strategy": "single_agent_fast_path",
    "default_verification": true,
    "default_memory_writeback": true
  },
  "contracts": {
    "objective_contract": {
      "objective_id": "string",
      "user_request": "string",
      "normalized_objective": "string",
      "domain_tags": [
        "string"
      ],
      "deliverable_types": [
        "analysis|code|doc|test|release|ops|memory"
      ],
      "constraints": {
        "time_sensitivity": "low|medium|high",
        "security_sensitivity": "low|medium|high",
        "performance_sensitivity": "low|medium|high",
        "architecture_impact": "none|local|cross_module|cross_system",
        "release_impact": "none|minor|major",
        "memory_required": "boolean",
        "audit_required": "boolean"
      },
      "context": {
        "repo_available": "boolean",
        "artifacts_available": "boolean",
        "historical_memory_available": "boolean",
        "external_systems_involved": [
          "string"
        ]
      },
      "preferences": {
        "prefer_fast_path": "boolean",
        "allow_swarm": "boolean",
        "require_spec_first": "boolean"
      }
    },
    "result_contract": {
      "objective_id": "string",
      "route_id": "string",
      "selected_topology": "single|pipeline|parallel_swarm|hierarchical_swarm",
      "selected_modes": [
        "string"
      ],
      "execution_status": "success|partial|failed|blocked",
      "deliverables": {
        "summaries": [
          "string"
        ],
        "artifacts": [
          "string"
        ],
        "changed_files": [
          "string"
        ],
        "tests": [
          "string"
        ],
        "issues": [
          "string"
        ]
      },
      "governance": {
        "security_review_required": "boolean",
        "performance_review_required": "boolean",
        "verification_status": "pass|warn|fail",
        "blockers": [
          "string"
        ]
      },
      "memory": {
        "writeback_status": "pending|written|skipped",
        "namespaces": [
          "string"
        ],
        "stored_items": [
          "string"
        ]
      },
      "next_actions": [
        "string"
      ]
    },
    "handoff_contract": {
      "from_mode": "string",
      "to_mode": "string",
      "objective_id": "string",
      "route_id": "string",
      "summary": "string",
      "artifacts": [
        "string"
      ],
      "findings": [
        "string"
      ],
      "decisions": [
        "string"
      ],
      "blockers": [
        "string"
      ],
      "assumptions": [
        "string"
      ],
      "requested_action": "string",
      "completion_hint": "string"
    },
    "verification_contract": {
      "checks": {
        "clarity": "pass|warn|fail",
        "completeness": "pass|warn|fail",
        "consistency": "pass|warn|fail",
        "security": "pass|warn|fail|not_applicable",
        "performance": "pass|warn|fail|not_applicable",
        "evidence": "pass|warn|fail"
      },
      "overall_verdict": "pass|warn|fail",
      "blockers": [
        "string"
      ],
      "confidence": "0.0..1.0",
      "ship_recommendation": "ship|ship_with_caveats|do_not_ship"
    }
  },
  "registry_item_schema": {
    "id": "string",
    "label": "string",
    "class": "mode|gate|support",
    "description": "string",
    "triggers": [
      "string"
    ],
    "use_when": [
      "string"
    ],
    "skip_when": [
      "string"
    ],
    "required_inputs": [
      "string"
    ],
    "optional_inputs": [
      "string"
    ],
    "produces": [
      "string"
    ],
    "side_effects": [
      "string"
    ],
    "dependencies": [
      "string"
    ],
    "handoff_to": [
      "string"
    ],
    "topology_support": [
      "single|pipeline|parallel_swarm|hierarchical_swarm"
    ],
    "risk_profile": "low|medium|high",
    "execution_cost": "low|medium|high",
    "memory_policy": "none|read|write|read_write",
    "completion_criteria": [
      "string"
    ]
  },
  "routing_dimensions": [
    "complexity",
    "ambiguity",
    "security_risk",
    "performance_risk",
    "architecture_impact",
    "delivery_scope",
    "memory_value"
  ],
  "complexity_rules": {
    "low": {
      "conditions": [
        "single deliverable",
        "single domain",
        "no architecture impact",
        "low security/performance risk"
      ],
      "route": "single_agent_fast_path"
    },
    "medium": {
      "conditions": [
        "multi-step",
        "2 domains",
        "local architecture impact"
      ],
      "route": "pipeline"
    },
    "high": {
      "conditions": [
        "3+ domains",
        "cross-module or cross-system impact",
        "security or performance sensitivity",
        "multiple artifacts"
      ],
      "route": "full_orchestrated_path"
    },
    "extreme": {
      "conditions": [
        "3+ independent workstreams",
        "needs parallel specialists",
        "high-risk cross-system release"
      ],
      "route": "swarm_path"
    }
  },
  "topology_rules": [
    {
      "name": "single_fast_path",
      "if_all": [
        "complexity <= 1",
        "ambiguity <= 1",
        "security_risk <= 1",
        "architecture_impact <= 1"
      ],
      "select": {
        "topology": "single",
        "modes": [
          "research",
          "implementation",
          "verification"
        ]
      }
    },
    {
      "name": "spec_first_pipeline",
      "if_all": [
        "ambiguity >= 3",
        "complexity >= 2"
      ],
      "select": {
        "topology": "pipeline",
        "modes": [
          "research",
          "specification",
          "architecture",
          "implementation",
          "verification"
        ]
      }
    },
    {
      "name": "architecture_pipeline",
      "if_all": [
        "architecture_impact >= 3"
      ],
      "select": {
        "topology": "pipeline",
        "modes": [
          "scout",
          "research",
          "planner",
          "architecture",
          "implementation",
          "review",
          "test",
          "verification"
        ]
      }
    },
    {
      "name": "secure_delivery_pipeline",
      "if_all": [
        "security_risk >= 3"
      ],
      "select": {
        "topology": "pipeline",
        "modes": [
          "research",
          "specification",
          "architecture",
          "implementation",
          "security",
          "review",
          "test",
          "verification"
        ]
      }
    },
    {
      "name": "performance_pipeline",
      "if_all": [
        "performance_risk >= 3"
      ],
      "select": {
        "topology": "pipeline",
        "modes": [
          "research",
          "architecture",
          "implementation",
          "performance",
          "test",
          "verification"
        ]
      }
    },
    {
      "name": "release_pipeline",
      "if_all": [
        "delivery_scope >= 3"
      ],
      "select": {
        "topology": "pipeline",
        "modes": [
          "planner",
          "implementation",
          "review",
          "test",
          "github_release",
          "verification"
        ]
      }
    },
    {
      "name": "hierarchical_swarm",
      "if_all": [
        "complexity >= 4",
        "delivery_scope >= 4",
        "architecture_impact >= 3"
      ],
      "select": {
        "topology": "hierarchical_swarm",
        "modes": [
          "swarm_coordination",
          "scout",
          "research",
          "planner",
          "architecture",
          "implementation",
          "review",
          "test",
          "verification"
        ]
      }
    }
  ],
  "gate_injection": {
    "security": {
      "inject_if": "security_risk >= 3",
      "insert_after": "implementation"
    },
    "performance": {
      "inject_if": "performance_risk >= 3",
      "insert_after": "implementation"
    },
    "review": {
      "inject_if": "deliverable_types contains code",
      "insert_after": "implementation"
    },
    "test": {
      "inject_if": "deliverable_types contains code",
      "insert_after": "review"
    },
    "memory_learning": {
      "inject_if": "memory_value >= 2 or constraints.memory_required == true",
      "insert_before": "verification"
    },
    "verification": {
      "inject_if": "always",
      "insert_at_end": true
    }
  },
  "state_machine": {
    "states": [
      "intake",
      "normalized",
      "classified",
      "routed",
      "executing",
      "waiting_handoff",
      "blocked",
      "reroute_required",
      "verifying",
      "persistence",
      "completed",
      "failed"
    ],
    "transitions": [
      {
        "from": "intake",
        "to": "normalized",
        "when": "objective normalized"
      },
      {
        "from": "normalized",
        "to": "classified",
        "when": "routing dimensions scored"
      },
      {
        "from": "classified",
        "to": "routed",
        "when": "topology and modes selected"
      },
      {
        "from": "routed",
        "to": "executing",
        "when": "first mode invoked"
      },
      {
        "from": "executing",
        "to": "waiting_handoff",
        "when": "current mode completed and next mode pending"
      },
      {
        "from": "waiting_handoff",
        "to": "executing",
        "when": "next mode accepted handoff"
      },
      {
        "from": "executing",
        "to": "blocked",
        "when": "hard blocker or failed gate"
      },
      {
        "from": "blocked",
        "to": "reroute_required",
        "when": "fallback path available"
      },
      {
        "from": "reroute_required",
        "to": "routed",
        "when": "alternate route selected"
      },
      {
        "from": "executing",
        "to": "verifying",
        "when": "all required modes completed"
      },
      {
        "from": "verifying",
        "to": "persistence",
        "when": "verification pass or warn with allowed publish"
      },
      {
        "from": "verifying",
        "to": "blocked",
        "when": "verification fail"
      },
      {
        "from": "persistence",
        "to": "completed",
        "when": "memory writeback resolved"
      },
      {
        "from": "blocked",
        "to": "failed",
        "when": "no legal reroute exists"
      }
    ]
  },
  "standard_routes": {
    "route_fast_build": {
      "topology": "single",
      "modes": [
        "research",
        "implementation",
        "verification"
      ]
    },
    "route_new_feature": {
      "topology": "pipeline",
      "modes": [
        "research",
        "specification",
        "architecture",
        "implementation",
        "review",
        "test",
        "verification"
      ]
    },
    "route_secure_system": {
      "topology": "pipeline",
      "modes": [
        "scout",
        "research",
        "planner",
        "specification",
        "architecture",
        "implementation",
        "security",
        "review",
        "test",
        "verification"
      ]
    },
    "route_release": {
      "topology": "pipeline",
      "modes": [
        "planner",
        "implementation",
        "review",
        "test",
        "github_release",
        "verification"
      ]
    },
    "route_large_swarm": {
      "topology": "hierarchical_swarm",
      "modes": [
        "swarm_coordination",
        "scout",
        "research",
        "planner",
        "architecture",
        "implementation",
        "review",
        "test",
        "verification"
      ]
    }
  },
  "registry": [
    {
      "id": "scout",
      "label": "Scout Mode",
      "class": "mode",
      "description": "Fast reconnaissance to map territory, files, threats, and next best route.",
      "triggers": [
        "unknown codebase",
        "large workspace",
        "need initial map"
      ],
      "use_when": [
        "domain unclear",
        "need structural overview",
        "need fast triage"
      ],
      "skip_when": [
        "task already well scoped",
        "single known file change"
      ],
      "required_inputs": [
        "objective_id",
        "normalized_objective"
      ],
      "optional_inputs": [
        "repo_path",
        "artifact_paths"
      ],
      "produces": [
        "workspace_map",
        "relevant_files",
        "initial_risks",
        "next_mode_recommendation"
      ],
      "side_effects": [
        "may create reconnaissance notes"
      ],
      "dependencies": [],
      "handoff_to": [
        "research",
        "planner",
        "architecture",
        "implementation"
      ],
      "topology_support": [
        "single",
        "pipeline",
        "hierarchical_swarm"
      ],
      "risk_profile": "low",
      "execution_cost": "low",
      "memory_policy": "write",
      "completion_criteria": [
        "relevant surface mapped",
        "next route proposed"
      ]
    },
    {
      "id": "research",
      "label": "Research Mode",
      "class": "mode",
      "description": "Deep analysis of patterns, dependencies, historical choices, and implementation facts.",
      "triggers": [
        "need understanding",
        "dependency analysis",
        "legacy behavior"
      ],
      "use_when": [
        "answer not obvious",
        "need grounded understanding",
        "need technical synthesis"
      ],
      "skip_when": [
        "implementation path already proven and simple"
      ],
      "required_inputs": [
        "objective_id",
        "normalized_objective"
      ],
      "optional_inputs": [
        "workspace_map",
        "memory_refs"
      ],
      "produces": [
        "findings",
        "dependency_map",
        "anti_patterns",
        "technical_recommendations"
      ],
      "side_effects": [
        "may enrich memory"
      ],
      "dependencies": [],
      "handoff_to": [
        "planner",
        "specification",
        "architecture",
        "implementation",
        "verification"
      ],
      "topology_support": [
        "single",
        "pipeline",
        "parallel_swarm",
        "hierarchical_swarm"
      ],
      "risk_profile": "low",
      "execution_cost": "medium",
      "memory_policy": "read_write",
      "completion_criteria": [
        "facts synthesized",
        "decision-relevant insight produced"
      ]
    },
    {
      "id": "planner",
      "label": "Planner / GOAP Mode",
      "class": "mode",
      "description": "Decomposes objective into ordered executable tasks with risks and contingencies.",
      "triggers": [
        "multi-step objective",
        "cross-domain work",
        "uncertain sequencing"
      ],
      "use_when": [
        "dependencies matter",
        "critical path must be explicit"
      ],
      "skip_when": [
        "one-step request"
      ],
      "required_inputs": [
        "objective_id",
        "normalized_objective"
      ],
      "optional_inputs": [
        "findings",
        "workspace_map"
      ],
      "produces": [
        "work_plan",
        "milestones",
        "dependency_graph",
        "risk_map"
      ],
