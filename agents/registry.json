      "skip_when": [
        "small local edit"
      ],
      "required_inputs": [
        "objective_id",
        "normalized_objective"
      ],
      "optional_inputs": [
        "specification",
        "plan",
        "findings"
      ],
      "produces": [
        "architecture_decisions",
        "contracts",
        "boundaries",
        "risks",
        "tradeoffs"
      ],
      "side_effects": [
        "may require security/performance reviews"
      ],
      "dependencies": [
        "research"
      ],
      "handoff_to": [
        "implementation",
        "security",
        "performance",
        "verification"
