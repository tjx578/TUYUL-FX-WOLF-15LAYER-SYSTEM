# ══════════════════════════════════════════════════════════════════════════════
# TUYUL FX WOLF-15 LAYER SYSTEM — Railway Environment Template
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy the relevant section into each Railway service's Variables tab.
# Shared variables (Redis, Postgres) must be consistent across services that use them.
# JWT secrets are only needed by wolf15-api (the sole service running FastAPI auth).
#
# Use Railway reference variables where possible:
#   REDIS_URL=${{Redis.REDIS_URL}}
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Generate secrets:
#   openssl rand -hex 32
#
# ══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────
# │ SHARED — Set these on ALL Railway services
# └─────────────────────────────────────────────────────────────────────────────

# Redis (required for ALL services)
REDIS_URL=${{Redis.REDIS_URL}}

# PostgreSQL (required for API + Engine; optional for others)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# App identity
APP_NAME=tuyul-fx-wolf-15layer-system
APP_ENV=production
TRADING_MODE=paper
LOG_LEVEL=INFO

# Finnhub (required for Ingest; optional for Engine if CONTEXT_MODE=redis)
FINNHUB_API_KEY=<your-finnhub-api-key>

# News provider
NEWS_PROVIDER=forexfactory

# Telegram alerts (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ wolf15-api (railway.toml)
# └─────────────────────────────────────────────────────────────────────────────

# PORT is auto-injected by Railway
WOLF15_SERVICE_ROLE=api
CONTEXT_MODE=redis

# Auth secrets (only needed by this service — sole FastAPI with JWT auth)
DASHBOARD_JWT_SECRET=<openssl rand -hex 32>
DASHBOARD_API_KEY=<openssl rand -hex 24>

# CORS — add your Vercel production + preview domains
CORS_ORIGINS=https://tuyul-fx-dashboard.vercel.app
VERCEL_FRONTEND_URL=
CORS_ORIGIN_REGEX=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REQUESTS_PER_MIN=120

# WS hardening
WS_REQUIRE_AUTH=true
WS_PING_INTERVAL=15
WS_HEARTBEAT_TIMEOUT=30

# Governance (MUST stay false — constitutional)
ALLOW_MARKET_EXECUTION=false
ALLOW_DASHBOARD_WRITE=false
COMPLIANCE_MODE_DEFAULT=true

# Cookie settings (production: SameSite=none requires Secure=true)
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_DOMAIN=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ wolf15-engine (railway-engine.toml)
# └─────────────────────────────────────────────────────────────────────────────

# PORT is auto-injected by Railway → ENGINE_HEALTH_PORT
WOLF15_SERVICE_ROLE=engine
RUN_MODE=engine-only
CONTEXT_MODE=redis

# Engine reads candles from Redis Lists seeded by Ingest
CANDLE_HISTORY_KEY_PREFIXES=wolf15:candle_history,candle_history

# Prop firm mode
PROP_FIRM_MODE=true
MAX_CONCURRENT_TRADES=1

# ┌─────────────────────────────────────────────────────────────────────────────
# │ wolf15-ingest (railway-ingestor.toml)
# └─────────────────────────────────────────────────────────────────────────────

# PORT is auto-injected by Railway → INGEST_HEALTH_PORT
WOLF15_SERVICE_ROLE=ingest
CONTEXT_MODE=redis

# Finnhub keys (primary + optional secondary for rotation)
# FINNHUB_API_KEY=<set in shared section>
FINNHUB_API_KEY_SECONDARY=

# Warmup / circuit breaker
WOLF15_INGEST_CB_FAILURE_THRESHOLD=10
WOLF15_INGEST_CB_RECOVERY_TIMEOUT=90

# Producer heartbeat
INGEST_PRODUCER_HEARTBEAT_INTERVAL_SEC=5
INGEST_PRODUCER_FRESHNESS_SEC=20

# WS connect grace window (seconds)
INGEST_WS_CONNECT_GRACE_SEC=45

# ┌─────────────────────────────────────────────────────────────────────────────
# │ wolf15-orchestrator (railway-orchestrator.toml)
# └─────────────────────────────────────────────────────────────────────────────

# PORT is auto-injected by Railway → ORCHESTRATOR_HEALTH_PORT
WOLF15_SERVICE_ROLE=orchestrator
ORCHESTRATOR_CHANNEL=wolf15:orchestrator:commands
ORCHESTRATOR_COMPLIANCE_INTERVAL_SEC=5
ORCHESTRATOR_HEARTBEAT_INTERVAL_SEC=30
ORCHESTRATOR_LOOP_SLEEP_SEC=0.5

# ┌─────────────────────────────────────────────────────────────────────────────
# │ wolf15-execution (railway-execution.toml)
# └─────────────────────────────────────────────────────────────────────────────

WOLF15_SERVICE_ROLE=execution
CONTEXT_MODE=redis

# EA bridge
EA_BRIDGE_ENABLED=true

# Broker (if running MT5 bridge)
BROKER_EXECUTOR=off
BROKER_ACCOUNT_ID=
BROKER_SERVER=
BROKER_PASSWORD=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ Workers (backtest / montecarlo / regime)
# └─────────────────────────────────────────────────────────────────────────────

# wolf15-worker-backtest
WOLF15_WORKER_ENTRY=backtest

# wolf15-worker-montecarlo
WOLF15_WORKER_ENTRY=montecarlo

# wolf15-worker-regime
WOLF15_WORKER_ENTRY=regime

# ┌─────────────────────────────────────────────────────────────────────────────
# │ Dashboard (Vercel — NOT Railway)
# └─────────────────────────────────────────────────────────────────────────────
# Set these in Vercel project → Settings → Environment Variables:

# NEXT_PUBLIC_API_BASE_URL=https://wolf15-api-production.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://wolf15-api-production.up.railway.app

# ┌─────────────────────────────────────────────────────────────────────────────
# │ Observability Auth (all services exposing /health, /readyz, /metrics)
# └─────────────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Must be identical across ALL services that serve or scrape these endpoints.
OBSERVABILITY_AUTH_MODE=required
OBSERVABILITY_MACHINE_KEY=<openssl rand -hex 32>

# ┌─────────────────────────────────────────────────────────────────────────────
# │ Observability Telemetry (optional — all services)
# └─────────────────────────────────────────────────────────────────────────────

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENV=production
