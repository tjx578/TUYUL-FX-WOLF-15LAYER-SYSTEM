# Version control
.git
.gitignore

# CI/CD
.github/

# Environment & secrets
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker (avoid recursive copy)
Dockerfile
docker-compose*.yml

# Documentation (not needed at runtime)
*.md
docs/
LICENSE

# Storage snapshots & archives (runtime-generated, not baked into image)
storage/snapshots/
storage/archives/
storage/exports/

# OS junk
Thumbs.db
.DS_Store

# Notebooks (dev only)
*.ipynb
.ipynb_checkpoints/

# Tests (not needed in production image)
tests/
test_*.py
*_test.py
