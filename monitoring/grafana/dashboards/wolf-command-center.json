      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 74},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "CLOSED", "color": "green"}, "1": {"text": "HALF_OPEN", "color": "yellow"}, "2": {"text": "OPEN", "color": "red"}}}
          ]
        }
      },
      "targets": [
        {"expr": "wolf_circuit_breaker_state", "legendFormat": "{{name}}", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Kill Switch",
      "description": "Kill switch status. 1=TRIPPED (all trading halted).",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 74},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "NORMAL", "color": "green"}, "1": {"text": "TRIPPED", "color": "red"}}}
          ]
        }
      },
      "targets": [
        {"expr": "wolf_kill_switch_active", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest Pipeline Latency (per stage)",
      "description": "End-to-end latency per ingest pipeline stage. SLO threshold visible as annotation.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 82},
      "fieldConfig": {
        "defaults": {"unit": "ms"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(wolf_ingest_pipeline_latency_ms_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(wolf_ingest_pipeline_latency_ms_bucket[5m])) by (le, stage))",
          "legendFormat": "p99 {{stage}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Feed Stale & Reconnect Events",
      "description": "Rate of feed stale detections and reconnect attempts.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 82},
      "targets": [
        {
          "expr": "sum(rate(wolf_feed_stale_total[5m])) by (symbol) * 60",
          "legendFormat": "stale {{symbol}}",
          "refId": "A"
