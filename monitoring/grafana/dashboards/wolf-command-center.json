{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "uid": "wolf-command-center",
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "Pipeline Latency (p95, p99)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(wolf_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(wolf_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gate Pass Rate per Gate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (gate) (rate(wolf_pipeline_gate_result_total{result=\"PASS\"}[5m])) / clamp_min(sum by (gate) (rate(wolf_pipeline_gate_result_total[5m])), 1)",
          "legendFormat": "{{gate}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Tick-to-Verdict Latency Histogram",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(wolf_tick_to_verdict_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Signal Rate per Minute",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "sum(rate(wolf_signal_total[1m])) * 60", "refId": "A"}]
    },
    {
      "type": "gauge",
      "title": "Account Drawdown Gauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "wolf_account_drawdown_percent", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Memory per Service",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "process_resident_memory_bytes", "legendFormat": "{{job}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Redis Stream Lag",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [{"expr": "wolf_redis_stream_lag_seconds", "legendFormat": "{{stream}}", "refId": "A"}]
    },
    {
      "type": "traces",
      "title": "Trace Viewer (Tempo)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "tempo", "uid": "tempo"},
      "targets": [{"queryType": "traceql", "query": "{}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Gate Pass/Fail Rate (9 Constitutional Gates)",
      "description": "Per-gate pass rate over time. Shows which constitutional gates are failing most often.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "sum by (gate) (rate(wolf_pipeline_gate_result_total{result=\"PASS\"}[5m])) / clamp_min(sum by (gate) (rate(wolf_pipeline_gate_result_total[5m])), 1)",
          "legendFormat": "{{gate}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Verdict Distribution (1h)",
      "description": "Distribution of L12 verdict outcomes: EXECUTE_BUY, EXECUTE_SELL, HOLD, NO_TRADE, ABORT.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "sum by (verdict) (increase(wolf_pipeline_verdict_total[1h]))",
          "legendFormat": "{{verdict}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reflective Drift Ratio",
      "description": "Two-pass reflective drift (|pass1_abg - pass2_abg|). Threshold: 0.15 (GRANTED max), 0.20 (RESTRICTED max).",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.15},
              {"color": "red", "value": 0.20}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "wolf_reflective_drift_ratio",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Sovereignty Level per Symbol",
      "description": "Current sovereignty enforcement level per symbol. GRANTED=green, RESTRICTED=yellow, REVOKED=red.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "INACTIVE"}, "1": {"text": "ACTIVE"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "wolf_sovereignty_level",
          "legendFormat": "{{symbol}} / {{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "TRQ-3D Alpha / Beta / Gamma",
      "description": "TRQ-3D three-axis values per symbol. Alpha=regime coherence, Beta=FRPC, Gamma=meta integrity.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48},
      "targets": [
        {
          "expr": "wolf_trq3d_alpha",
          "legendFormat": "alpha {{symbol}}",
          "refId": "A"
        },
        {
          "expr": "wolf_trq3d_beta",
          "legendFormat": "beta {{symbol}}",
          "refId": "B"
        },
        {
          "expr": "wolf_trq3d_gamma",
          "legendFormat": "gamma {{symbol}}",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-Symbol TII / FRPC / CONF12 Scores",
      "description": "Constitutional score panel. Thresholds: TII≥0.60, FRPC≥0.93, CONF12≥0.75.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 0.60}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "wolf_tii_score",
          "legendFormat": "TII {{symbol}}",
          "refId": "A"
        },
        {
          "expr": "wolf_frpc_score",
          "legendFormat": "FRPC {{symbol}}",
          "refId": "B"
        },
        {
          "expr": "wolf_conf12_score",
          "legendFormat": "CONF12 {{symbol}}",
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "📈 Trading Performance",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 56},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Win Rate",
      "description": "Rolling win rate per symbol.",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 57},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.40},
              {"color": "green", "value": 0.55}
            ]
          }
        }
      },
      "targets": [{"expr": "wolf_win_rate", "legendFormat": "{{symbol}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Realized PnL",
      "description": "Running realized PnL per account.",
      "gridPos": {"h": 8, "w": 10, "x": 6, "y": 57},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 0}
            ]
          }
        }
      },
      "targets": [
        {"expr": "wolf_pnl_realized_current", "legendFormat": "{{account_id}}", "refId": "A"}
      ]
    },
    {
      "type": "gauge",
      "title": "Daily Loss %",
      "description": "Current daily loss as percentage of starting balance. Red threshold at 4% (FTMO), 5% (max).",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 57},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 4}
            ]
          }
        }
      },
      "targets": [
        {"expr": "wolf_daily_loss_percent", "legendFormat": "{{account_id}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Drawdown % (High-Water)",
      "description": "Maximum drawdown from high-water mark per account. Red at 8% (FTMO overall limit).",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 65},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 6},
              {"color": "red", "value": 8}
            ]
          }
        }
      },
      "targets": [
        {"expr": "wolf_drawdown_max_percent", "legendFormat": "{{account_id}}", "refId": "A"},
        {"expr": "wolf_account_drawdown_percent", "legendFormat": "current {{account_id}}", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Trade Outcomes (Win / Loss / BE)",
      "description": "Cumulative trade count by outcome per symbol.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 65},
      "targets": [
        {
          "expr": "sum by (outcome) (increase(wolf_trades_total[1h]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "🔌 Feed & Infrastructure Health",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 73},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Feed Age (seconds since last tick)",
      "description": "Per-symbol feed staleness. Alert threshold at 30s.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 74},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 15},
              {"color": "red", "value": 30}
            ]
          }
        }
      },
      "targets": [
        {"expr": "wolf_feed_age_seconds", "legendFormat": "{{symbol}}", "refId": "A"}
