  "panels": [
    {
      "type": "timeseries",
      "title": "Pipeline Latency (p95, p99)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(wolf_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(wolf_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Allocation Approval Rate per Account",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (account_id) (rate(wolf_alloc_success_total[5m])) / clamp_min(sum by (account_id) (rate(wolf_alloc_success_total[5m])) + sum by (account_id) (rate(wolf_alloc_reject_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Execution Latency Histogram",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(wolf_execution_latency_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Signal Rate per Minute",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "sum(rate(wolf_signal_total[1m])) * 60", "refId": "A"}]
    },
    {
