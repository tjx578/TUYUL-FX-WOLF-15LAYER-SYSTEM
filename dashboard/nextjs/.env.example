# Railway Backend API (analysis-engine public domain)
# This MUST match what src/lib/env.ts reads: NEXT_PUBLIC_API_BASE_URL
NEXT_PUBLIC_API_BASE_URL=https://analysis-engine-production-ae87.up.railway.app

# WebSocket endpoint (jika pakai WS realtime)
NEXT_PUBLIC_WS_URL=wss://analysis-engine-production-ae87.up.railway.app

# Timezone for UI display only
NEXT_PUBLIC_TIMEZONE=Asia/Singapore

# Refresh intervals (milliseconds)
NEXT_PUBLIC_VERDICT_REFRESH_MS=5000
NEXT_PUBLIC_CONTEXT_REFRESH_MS=10000
NEXT_PUBLIC_HEALTH_REFRESH_MS=30000