# ============================================================
# TUYUL FX Wolf-15 — Frontend Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Backend URL (Railway deployment)
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app

# Timezone for display (Singapore/Jakarta = Asia/Singapore or Asia/Jakarta)
NEXT_PUBLIC_TIMEZONE=Asia/Singapore

# Refresh intervals (milliseconds)
NEXT_PUBLIC_VERDICT_REFRESH_MS=5000
NEXT_PUBLIC_CONTEXT_REFRESH_MS=10000
NEXT_PUBLIC_HEALTH_REFRESH_MS=30000
