# v3
# DEPRECATED — use NEXT_PUBLIC_API_BASE_URL and INTERNAL_API_URL instead:
# NEXT_PUBLIC_API_URL=http://localhost:8000/api
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live

# Server-side only (used by next.config.js rewrites and session.ts).
# Must be the BASE origin — NO /api suffix!
# The rewrite rules in next.config.js already append /api/:path*.
INTERNAL_API_URL=http://localhost:8000

# ============================================================
# TUYUL FX Wolf-15 — Frontend Environment Variables
# Vercel: Project Settings → Environment Variables
# Local:  cp .env.example .env.local
# ============================================================

# ── REST API base URL (no trailing slash) ───────────────────
# Production (Railway):  https://your-api.up.railway.app
# Dev/local:             http://localhost:8000
# This is used by next.config.js rewrites AND apiClient.ts
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── WebSocket base URL (bare origin ONLY — no path, no trailing slash) ──────
# MUST be the bare wss:// or ws:// origin — protocol+host only, NOTHING else.
# The individual hooks already append /ws/<channel> to build the full URL.
#
# ✅ CORRECT:   NEXT_PUBLIC_WS_BASE_URL=wss://wolf15-api-production.up.railway.app
# ❌ WRONG:     NEXT_PUBLIC_WS_BASE_URL=wss://wolf15-api-production.up.railway.app/ws/live
# ❌ WRONG:     NEXT_PUBLIC_WS_BASE_URL=wss://wolf15-api-production.up.railway.app/ws
# ❌ WRONG:     NEXT_PUBLIC_WS_BASE_URL=wss://wolf15-api-production.up.railway.app/
#
# Including a path causes DOUBLE-PATH connections at runtime:
#   wss://host/ws/live + /ws/live → wss://host/ws/live/ws/live  (broken!)
#
# If this var includes any path, the build will fail on protected deployments
# and validateEnv() will throw ConfigError (showing a degraded mode banner).
#
# Production:  wss://your-api.up.railway.app
# Dev/local:   ws://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ── Timezone for UI display only ────────────────────────────
NEXT_PUBLIC_TIMEZONE=Asia/Singapore

# ── Poll / refresh intervals (milliseconds) ─────────────────
NEXT_PUBLIC_VERDICT_REFRESH_MS=5000
NEXT_PUBLIC_CONTEXT_REFRESH_MS=10000
NEXT_PUBLIC_HEALTH_REFRESH_MS=30000

# ── Optional: governance pin for write actions ──────────────
# NEXT_PUBLIC_ACTION_PIN=

# ── API key for service-mode access (fallback when no JWT) ──
# Production: set to your backend API key in Vercel env vars
# NEXT_PUBLIC_API_KEY=

# ── Server-only API key for middleware auth injection ────────
# The Edge middleware reads this to inject Authorization headers
# into proxied API requests when no session cookie is present.
# Must match DASHBOARD_API_KEY on the backend.  NOT exposed to
# the browser bundle (no NEXT_PUBLIC_ prefix).
# API_KEY=

# ── Signals domain (Stage 2) ────────────────────────────────
# Operator identifier injected into take-signal payloads.
# Defaults to "owner:dashboard" if unset.
# NEXT_PUBLIC_DASHBOARD_OPERATOR_ID=owner:dashboard

# Default reason string pre-filled in the take-signal drawer.
# Operators can override before submitting.
# NEXT_PUBLIC_DEFAULT_TAKE_REASON=MANUAL_OPERATOR_TAKE

# How often (ms) to poll the verdict endpoint when WebSocket
# is disabled or unavailable.  Defaults to 30000.
# NEXT_PUBLIC_SIGNAL_REFRESH_INTERVAL_MS=30000

# Set to "false" to disable the real-time WebSocket feed and
# fall back to polling only.  Defaults to "true".
# NEXT_PUBLIC_SIGNAL_WS_ENABLED=true
