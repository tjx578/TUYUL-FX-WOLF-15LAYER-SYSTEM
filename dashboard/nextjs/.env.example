# ============================================================
# TUYUL FX Wolf-15 — Frontend (Vercel / Next.js)
# ============================================================

# Railway Backend API (no trailing slash)
# Replace with your actual production API domain
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket endpoint (jika pakai WS realtime)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Backward-compatible alias (some frontend modules may still read this key)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Timezone for UI display only
NEXT_PUBLIC_TIMEZONE=Asia/Singapore

# Refresh intervals (milliseconds)
NEXT_PUBLIC_VERDICT_REFRESH_MS=5000
NEXT_PUBLIC_CONTEXT_REFRESH_MS=10000
NEXT_PUBLIC_HEALTH_REFRESH_MS=30000

# --- Dashboard API ---
# URL of the Wolf-15 backend API (no trailing slash)
# Vercel: set in Project Settings → Environment Variables (Production + Preview + Development)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000