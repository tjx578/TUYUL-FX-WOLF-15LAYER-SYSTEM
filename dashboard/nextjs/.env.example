# =======================================
# NEXT.JS DASHBOARD ENVIRONMENT VARIABLES
# =======================================

# API Backend URL
# Development: http://localhost:8000
# Production: https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (ws:// for dev, wss:// for production)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# WebSocket authentication token (JWT or API key)
NEXT_PUBLIC_WS_TOKEN=CHANGE_ME

# Timezone for display
NEXT_PUBLIC_TIMEZONE=Asia/Singapore

# Refresh intervals (milliseconds) — for SWR polling fallback
NEXT_PUBLIC_VERDICT_REFRESH_MS=5000
NEXT_PUBLIC_CONTEXT_REFRESH_MS=10000
NEXT_PUBLIC_HEALTH_REFRESH_MS=30000

# Dashboard title
NEXT_PUBLIC_APP_NAME="TUYUL FX WOLF 15-LAYER"

# Feature flags
NEXT_PUBLIC_ENABLE_DEBUG=false
