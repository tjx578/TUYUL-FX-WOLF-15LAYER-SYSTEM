# =========================
# Secrets / Env
# =========================
.env
.env.*
!.env.example
ghpt.txt

# ── Python artifacts ─────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── Debug / scratch / probe artifacts ────────
# Catch-all: any root-level .txt except requirements.txt and known tracked files
/*.txt
!requirements.txt
# Catch-all: underscore-prefixed scratch scripts
/_*
/._*
# Scratch "old pattern" / comparison files (emoji-named junk)
**/\#\ *

# ── Test output ──────────────────────────────
test-results/
htmlcov/
.coverage
.coveragerc
coverage.xml
.pytest_cache/
pytest_cache/

# ── Build artifacts ──────────────────────────
final_results.txt
full_results.txt
collect_results.txt
full_test_run.txt
test_collect.txt
*.log
*.out

# ── Environment ──────────────────────────────
.env
.env.local
.env.*.local
.venv/

# ── Node / JS ────────────────────────────────
# Ghost root Next.js configs (real dashboard lives in dashboard/nextjs/)
/next.config.*
/package.json
/pnpm-lock.yaml
/postcss.config.*
/tsconfig.json
node_modules/
**/node_modules/
/package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
out/

# ── IDE ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.cursor/
.windsurf/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Ruff / Mypy / Pyright cache ─────────────
.ruff_cache/
.mypy_cache/
.pyright/

# ── OS files ─────────────────────────────────
Thumbs.db
.DS_Store

# ── Forensic audit trail (append-only at runtime; not a code artifact) ───────
storage/forensics/replay_artifacts.jsonl

# ── Decision archive runtime outputs ─────────────────────────────────────────
storage/decision_archive/2026-*/
