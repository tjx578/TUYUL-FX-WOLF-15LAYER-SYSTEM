{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "l12_signal_schema_v2",
  "title": "Wolf L12 Signal Contract",
  "description": "Full L12 verdict/signal contract. Must NOT contain account-level state (balance, equity). Position sizing is dashboard authority.",
  "type": "object",
  "required": [
    "signal_id",
    "symbol",
    "verdict",
    "confidence",
    "timestamp"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "description": "Unique signal identifier",
      "pattern": "^SIG-[A-Z0-9]+-[0-9]+$"
    },
    "symbol": {
      "type": "string",
      "description": "Trading pair/symbol",
      "examples": ["EURUSD", "GBPJPY", "XAUUSD"]
    },
    "verdict": {
      "type": "string",
      "enum": ["EXECUTE", "HOLD", "NO_TRADE", "ABORT"],
      "description": "L12 constitutional verdict — sole decision authority"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Combined analysis confidence score"
    },
    "direction": {
      "type": "string",
      "enum": ["BUY", "SELL"],
      "description": "Trade direction. Only present if verdict=EXECUTE"
    },
    "entry_price": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Proposed entry price"
    },
    "stop_loss": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Proposed SL price"
    },
    "take_profit_1": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Primary take profit"
    },
    "take_profit_2": {
      "type": ["number", "null"],
      "description": "Secondary take profit (optional)"
    },
    "risk_reward_ratio": {
      "type": "number",
      "minimum": 0,
      "description": "Computed RR from entry/SL/TP"
    },
    "scores": {
      "type": "object",
      "description": "Layer scores from analysis",
      "properties": {
        "wolf_score": {"type": "number"},
        "tii_score": {"type": "number"},
        "frpc_score": {"type": "number"},
        "regime": {"type": "string"},
        "session": {"type": "string"}
      }
    },
    "timestamp": {
      "type": "number",
      "description": "Unix epoch when verdict was issued"
    },
    "expires_at": {
      "type": "number",
      "description": "Unix epoch when signal becomes invalid"
    },
    "layers_summary": {
      "type": "object",
      "description": "Summary output from each analysis layer",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "not": {
    "description": "CONSTITUTIONAL: L12 signal must NEVER contain account-level state",
    "anyOf": [
      {"required": ["balance"]},
      {"required": ["equity"]},
      {"required": ["account_balance"]},
      {"required": ["lot_size"]},
      {"required": ["risk_amount"]}
    ]
  }
}