{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alert Schema",
  "type": "object",
  "required": ["type", "message", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "L12_PASSED",
        "L12_REJECTED",
        "ORDER_PLACED",
        "ORDER_CANCELLED",
        "ORDER_EXPIRED",
        "ORDER_FILLED",
        "SYSTEM_VIOLATION"
      ]
    },
    "message": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
